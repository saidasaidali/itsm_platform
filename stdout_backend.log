         FROM assets a
         JOIN asset_live_state ls ON ls.asset_id = a.id
         WHERE a.type IN ('Ordinateur', 'Serveur')
           AND a.status = 'En service'
           AND ls.disk_free_gb IS NOT NULL
           AND ls.disk_free_gb < $1
           AND ls.disk_free_gb > 0
