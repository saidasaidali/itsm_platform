# ═══════════════════════════════════════════════════
# ITSM Platform - Configuration d'environnement
# ═══════════════════════════════════════════════════
# Copiez ce fichier en .env et modifiez les valeurs
# cp .env.example .env
# ═══════════════════════════════════════════════════

# ─── Environnement ───
NODE_ENV=production

# ─── Base de données PostgreSQL ───
DB_HOST=postgres
DB_PORT=5432
DB_USER=itsm_user
DB_PASSWORD=changez_moi_par_un_mot_de_passe_fort
DB_NAME=itsm_db

# ─── Ports exposés ───
BACKEND_PORT=3000
FRONTEND_PORT=3001

# ─── Sécurité ───
JWT_SECRET=votre_cle_secrete_jwt_tres_longue_et_aleatoire
JWT_EXPIRES_IN=24h

# ─── API Frontend ───
# URL accessible depuis le navigateur du client
VITE_API_URL=http://localhost:3000

# ─── Options avancées ───
# Pour activer FastAPI ML (optionnel)
# ML_API_URL=http://localhost:8000

# Pour activer Ollama (optionnel)
# OLLAMA_URL=http://localhost:11434
