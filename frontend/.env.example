# ===========================================
# ITSM Platform - Frontend Configuration
# ===========================================
# Copiez ce fichier vers .env et remplissez les valeurs
# cp .env.example .env

# -------------------------------------------
# API Configuration
# -------------------------------------------
# URL de l'API backend
VITE_API_URL=http://localhost:3000

# -------------------------------------------
# Application
# -------------------------------------------
# Nom de l'application
VITE_APP_NAME=ITSM Platform

# Version de l'application
VITE_APP_VERSION=1.0.0

# Description de l'application
VITE_APP_DESCRIPTION=Système de Gestion des Tickets IT

# -------------------------------------------
# Environnement
# -------------------------------------------
# Environnement: development, staging, production
VITE_NODE_ENV=development

# Mode debug (affiche les logs détaillés)
VITE_DEBUG=true

# -------------------------------------------
# Internationalisation (i18n)
# -------------------------------------------
# Langue par défaut: fr, en, ar
VITE_DEFAULT_LANGUAGE=fr

# Langues disponibles (séparées par des virgules)
VITE_AVAILABLE_LANGUAGES=fr,en,ar

# -------------------------------------------
# Thème
# -------------------------------------------
# Thème par défaut: light, dark, auto
VITE_DEFAULT_THEME=light

# Thèmes disponibles
VITE_AVAILABLE_THEMES=light,dark,auto

# -------------------------------------------
# Authentification
# -------------------------------------------
# Token storage key (localStorage)
VITE_TOKEN_KEY=itsm-auth-token

# User storage key (localStorage)
VITE_USER_KEY=itsm-user

# Token expiration check interval (en ms)
VITE_TOKEN_CHECK_INTERVAL=300000

# -------------------------------------------
# Notifications
# -------------------------------------------
# Polling interval pour les notifications (en ms)
VITE_NOTIFICATION_POLL_INTERVAL=30000

# Nombre maximum de notifications à charger
VITE_NOTIFICATION_MAX_LOAD=50

# -------------------------------------------
# Uploads
# -------------------------------------------
# Taille maximale des fichiers (en bytes) - 10MB par défaut
VITE_MAX_FILE_SIZE=10485760

# Types de fichiers autorisés pour l'upload Excel
VITE_ALLOWED_EXCEL_TYPES=.xlsx,.xls

# -------------------------------------------
# Pagination
# -------------------------------------------
# Nombre d'éléments par page par défaut
VITE_DEFAULT_PAGE_SIZE=20

# Options de pagination
VITE_PAGE_SIZE_OPTIONS=10,20,50,100

# -------------------------------------------
# Tableau de Bord
# -------------------------------------------
# Intervalle de rafraîchissement du dashboard (en ms)
VITE_DASHBOARD_REFRESH_INTERVAL=300000

# Nombre de tickets à afficher dans les statistiques
VITE_DASHBOARD_TOP_TICKETS_LIMIT=5

# -------------------------------------------
# Chatbot
# -------------------------------------------
# URL du service chatbot (si différent de l'API principale)
VITE_CHATBOT_URL=

# Timeout des requêtes chatbot (en ms)
VITE_CHATBOT_TIMEOUT=30000

# Nombre maximum de messages dans l'historique
VITE_CHATBOT_MAX_HISTORY=50

# -------------------------------------------
# Cartographie Réseau
# -------------------------------------------
# URL du service de cartographie (si différent)
VITE_NETWORK_MAP_URL=

# Intervalle de rafraîchissement de la carte (en ms)
VITE_NETWORK_MAP_REFRESH_INTERVAL=60000

# -------------------------------------------
# ML Service (Optionnel)
# -------------------------------------------
# URL du service ML (si activé)
VITE_ML_SERVICE_URL=http://localhost:5000

# Activer les fonctionnalités ML
VITE_ML_ENABLED=true

# -------------------------------------------
# Performance
# -------------------------------------------
# Activer le cache des requêtes API
VITE_API_CACHE_ENABLED=true

# Durée du cache (en ms) - 5 minutes par défaut
VITE_API_CACHE_DURATION=300000

# Activer le lazy loading des composants
VITE_LAZY_LOADING=true

# -------------------------------------------
# Développement
# -------------------------------------------
# Activer les outils de développement
VITE_DEV_TOOLS=true

# Activer les logs API
VITE_LOG_API_CALLS=true

# Activer les logs d'erreur détaillés
VITE_LOG_ERRORS=true

# Proxy API (pour le développement)
# Si votre API est sur un port différent, utilisez un proxy
VITE_USE_PROXY=false

# -------------------------------------------
# Features Flags (Fonctionnalités)
# -------------------------------------------
# Activer le scan réseau
VITE_FEATURE_NETWORK_SCAN=true

# Activer l'import Excel
VITE_FEATURE_EXCEL_IMPORT=true

# Activer les QR Codes
VITE_FEATURE_QR_CODES=true

# Activer le chatbot vocal
VITE_FEATURE_VOICE_CHAT=true

# Activer les exports PDF
VITE_FEATURE_PDF_EXPORT=false

# Activer les rapports avancés
VITE_FEATURE_ADVANCED_REPORTS=false

# Activer le monitoring temps réel
VITE_FEATURE_REALTIME_MONITORING=true

# -------------------------------------------
# UI Configuration
# -------------------------------------------
# Layout: vertical, horizontal
VITE_DEFAULT_LAYOUT=vertical

# Sidebar: fixed, static, overlay
VITE_SIDEBAR_TYPE=fixed

# Taille de la sidebar: sm, md, lg
VITE_SIDEBAR_SIZE=md

# Afficher le breadcrumb
VITE_SHOW_BREADCRUMB=true

# Afficher le footer
VITE_SHOW_FOOTER=true

# -------------------------------------------
# Timeouts (en ms)
# -------------------------------------------
# Timeout des requêtes API
VITE_API_TIMEOUT=30000

# Timeout des uploads
VITE_UPLOAD_TIMEOUT=60000

# Timeout du chatbot
VITE_CHATBOT_REQUEST_TIMEOUT=30000

# -------------------------------------------
# Messages & Notifications
# -------------------------------------------
# Durée d'affichage des toasts (en ms)
VITE_TOAST_DURATION=5000

# Position des toasts: top-right, top-left, bottom-right, bottom-left
VITE_TOAST_POSITION=top-right

# -------------------------------------------
# Exemples de Configuration
# -------------------------------------------

# Développement Local:
# VITE_API_URL=http://localhost:3000
# VITE_NODE_ENV=development
# VITE_DEBUG=true
# VITE_DEFAULT_LANGUAGE=fr
# VITE_DEFAULT_THEME=light

# Production:
# VITE_API_URL=https://api.dresi.gov
# VITE_NODE_ENV=production
# VITE_DEBUG=false
# VITE_DEFAULT_LANGUAGE=fr
# VITE_DEFAULT_THEME=auto
# VITE_LOG_API_CALLS=false
# VITE_LOG_ERRORS=false

# Staging:
# VITE_API_URL=https://api-staging.dresi.gov
# VITE_NODE_ENV=staging
# VITE_DEBUG=true
# VITE_DEFAULT_LANGUAGE=fr

# -------------------------------------------
# Notes de Configuration
# -------------------------------------------
# 1. Copiez ce fichier: cp .env.example .env
# 2. Modifiez les valeurs selon votre environnement
# 3. Ne committez JAMAIS le fichier .env (il est dans .gitignore)
# 4. Les variables VITE_* sont accessibles dans le code via import.meta.env
# 5. Redémarrez le serveur après modification des variables

# -------------------------------------------
# Utilisation dans le Code
# -------------------------------------------
# Exemple d'utilisation dans un composant React:
# const apiUrl = import.meta.env.VITE_API_URL
# const isDev = import.meta.env.VITE_NODE_ENV === 'development'

# Exemple d'utilisation dans un service:
# const API_URL = import.meta.env.VITE_API_URL || 'http://localhost:3000'