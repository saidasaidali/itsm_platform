# ===========================================
# ITSM Platform - Backend Configuration
# ===========================================
# Copiez ce fichier vers .env et remplissez les valeurs
# cp .env.example .env

# -------------------------------------------
# Base de Données PostgreSQL
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=itsm_platform
DB_USER=postgres
DB_PASSWORD=your_password_here

# -------------------------------------------
# Authentification JWT
# -------------------------------------------
JWT_SECRET=your_jwt_secret_key_min_32_characters_long
JWT_EXPIRES_IN=7d

# -------------------------------------------
# Serveur Backend
# -------------------------------------------
PORT=3000
NODE_ENV=development

# -------------------------------------------
# Frontend URL (pour les emails et CORS)
# -------------------------------------------
FRONTEND_URL=http://localhost:3001

# -------------------------------------------
# Configuration SMTP (Emails)
# -------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=noreply@dresi.gov

# -------------------------------------------
# Agent Heartbeat (Optionnel)
# Clé secrète pour l'agent Windows de heartbeat
# -------------------------------------------
ASSET_AGENT_KEY=your_secret_key_for_heartbeat_agent

# -------------------------------------------
# Configuration Réseau (Optionnel)
# -------------------------------------------
# Plage IP pour le scan réseau
NETWORK_SCAN_BASE_IP=192.168.1
NETWORK_SCAN_START=1
NETWORK_SCAN_END=254

# -------------------------------------------
# Configuration Active Directory (Optionnel)
# -------------------------------------------
AD_SERVER=ldap://your-ad-server.com
AD_DOMAIN=DRESI
AD_USERNAME=service_account
AD_PASSWORD=service_password

# -------------------------------------------
# Configuration ML Service (Optionnel)
# -------------------------------------------
ML_SERVICE_URL=http://localhost:5000
ML_SERVICE_ENABLED=true

# -------------------------------------------
# Configuration des Logs (Optionnel)
# -------------------------------------------
LOG_LEVEL=info
LOG_FILE=logs/app.log

# -------------------------------------------
# Configuration des Tâches Planifiées (Optionnel)
# -------------------------------------------
# SLA Monitor - Vérification toutes les X minutes
SLA_CHECK_INTERVAL=15

# Ticket Monitor - Vérification toutes les X minutes
TICKET_MONITOR_INTERVAL=30

# Auto-Ticketing - Vérification toutes les X heures
AUTO_TICKETING_INTERVAL=1

# Network Discovery - Scan SNMP (cron format)
SNMP_SCAN_SCHEDULE=0 2 * * *

# Network Discovery - Scan AD (cron format)
AD_SCAN_SCHEDULE=0 3 * * *

# -------------------------------------------
# Configuration des Notifications (Optionnel)
# -------------------------------------------
# Nombre maximum de notifications à afficher
MAX_NOTIFICATIONS_DISPLAY=50

# Fréquence de nettoyage des anciennes notifications (en jours)
NOTIFICATION_CLEANUP_DAYS=90

# -------------------------------------------
# Configuration des Uploads (Optionnel)
# -------------------------------------------
# Taille maximale des fichiers (en bytes)
MAX_FILE_SIZE=10485760

# Types de fichiers autorisés pour l'upload
ALLOWED_FILE_TYPES=.xlsx,.xls

# -------------------------------------------
# Configuration de Sécurité (Optionnel)
# -------------------------------------------
# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS - Origines autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# -------------------------------------------
# Configuration du Chatbot (Optionnel)
# -------------------------------------------
CHATBOT_SESSION_TIMEOUT=3600
CHATBOT_MAX_HISTORY=50

# -------------------------------------------
# Configuration des Assets (Optionnel)
# -------------------------------------------
# Seuil d'espace disque critique (en GB)
DISK_SPACE_THRESHOLD_GB=5

# Seuil de jours pour PC non détecté
PC_MISSING_DAYS_THRESHOLD=3

# Seuil d'heures pour imprimante hors ligne
PRINTER_OFFLINE_HOURS_THRESHOLD=2

# -------------------------------------------
# Configuration des QR Codes (Optionnel)
# -------------------------------------------
QR_CODE_SIZE=200
QR_CODE_ERROR_CORRECTION=M

# -------------------------------------------
# Configuration des Exports (Optionnel)
# -------------------------------------------
EXPORT_MAX_ROWS=10000
EXPORT_DATE_FORMAT=DD/MM/YYYY

# -------------------------------------------
# Configuration des Imports Excel (Optionnel)
# -------------------------------------------
IMPORT_SHEET_INDEX=0
IMPORT_HAS_HEADER=true

# -------------------------------------------
# Configuration des SLA (Optionnel)
# -------------------------------------------
# SLA par défaut pour les tickets (en heures)
SLA_DEFAULT_HOURS=24

# SLA Haute priorité (en heures)
SLA_HIGH_PRIORITY_HOURS=4

# SLA Basse priorité (en heures)
SLA_LOW_PRIORITY_HOURS=72

# -------------------------------------------
# Configuration des Rôles (Optionnel)
# -------------------------------------------
# Rôle Admin
ROLE_ADMIN_ID=1
ROLE_ADMIN_NAME=Admin

# Rôle Technicien
ROLE_TECHNICIAN_ID=2
ROLE_TECHNICIAN_NAME=Technicien

# Rôle Agent
ROLE_AGENT_ID=3
ROLE_AGENT_NAME=Agent

# -------------------------------------------
# Configuration des Statuts (Optionnel)
# -------------------------------------------
# Statuts des tickets
TICKET_STATUS_NEW=Nouveau
TICKET_STATUS_ASSIGNED=Assigné
TICKET_STATUS_IN_PROGRESS=En cours
TICKET_STATUS_PENDING=En attente
TICKET_STATUS_RESOLVED=Résolu
TICKET_STATUS_CLOSED=Clôturé
TICKET_STATUS_REOPENED=Rouvert

# Statuts des assets
ASSET_STATUS_IN_SERVICE=En service
ASSET_STATUS_OUT_OF_SERVICE=En panne
ASSET_STATUS_OUT_OF_ORDER=Hors service
ASSET_STATUS_IN_STOCK=En stock
ASSET_STATUS_IN_MAINTENANCE=En maintenance
ASSET_STATUS_RETIRED=Retiré

# Statuts des utilisateurs
USER_STATUS_ACTIVE=active
USER_STATUS_PENDING=pending
USER_STATUS_INACTIVE=inactive

# -------------------------------------------
# Configuration des Priorités (Optionnel)
# -------------------------------------------
PRIORITY_LOW=Basse
PRIORITY_MEDIUM=Moyenne
PRIORITY_HIGH=Haute
PRIORITY_CRITICAL=Critique

# -------------------------------------------
# Configuration des Catégories (Optionnel)
# -------------------------------------------
CATEGORY_HARDWARE=Matériel
CATEGORY_SOFTWARE=Logiciel
CATEGORY_NETWORK=Réseau
CATEGORY_PRINTER=Imprimante
CATEGORY_EMAIL=Email
CATEGORY_ACCESS=Accès
CATEGORY_OTHER=Autre

# -------------------------------------------
# Notes de Configuration
# -------------------------------------------
# 1. Copiez ce fichier: cp .env.example .env
# 2. Modifiez les valeurs selon votre environnement
# 3. Ne committez JAMAIS le fichier .env (il est dans .gitignore)
# 4. Utilisez des mots de passe forts pour JWT_SECRET et SMTP_PASS
# 5. Pour Gmail, utilisez un "Mot de passe d'application"