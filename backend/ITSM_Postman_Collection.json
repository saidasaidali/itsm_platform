{
  "info": {
    "name": "ITSM Platform - Module A",
    "description": "Tests authentification et gestion des utilisateurs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000/api" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Token présent', () => pm.expect(json.token).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"admin@ministere.ma\",\n  \"password\": \"Admin@1234\"\n}"
            }
          }
        },
        {
          "name": "Register (Admin only)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/register",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"technicien1\",\n  \"email\": \"tech1@ministere.ma\",\n  \"password\": \"Tech@1234\",\n  \"role_id\": 2\n}"
            }
          }
        },
        {
          "name": "Me (profil connecté)",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET tous les utilisateurs",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "GET utilisateur par ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/users/1",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        },
        {
          "name": "POST créer utilisateur (Admin)",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/users",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"agent_dupont\",\n  \"email\": \"dupont@ministere.ma\",\n  \"password\": \"Agent@5678\",\n  \"role_id\": 3\n}"
            }
          }
        },
        {
          "name": "PUT modifier utilisateur (Admin)",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/users/2",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nouveau@ministere.ma\",\n  \"role_id\": 2\n}"
            }
          }
        },
        {
          "name": "DELETE supprimer utilisateur (Admin)",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/users/3",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }]
          }
        }
      ]
    }
  ]
}
